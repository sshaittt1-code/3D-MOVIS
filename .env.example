# Runtime environment for local development / Cloud Run
NODE_ENV="development"

# Telegram API credentials
# Get these from https://my.telegram.org by creating an application
TG_API_ID=""
TG_API_HASH=""

# Catalog enrichment
# Optional but recommended. Used for IMDb/OMDb metadata.
OMDB_API_KEY=""

# Optional TMDB key for a larger movie/series catalog.
TMDB_API_KEY=""

# Cloud Run injects PORT automatically. Leave empty locally unless you want a custom port.
PORT="3000"
