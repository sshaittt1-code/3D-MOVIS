{
  "name": "react-example",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test src/utils/*.test.ts",
    "smoke:feeds": "node scripts/feedSmoke.mjs",
    "smoke:feeds:local": "node scripts/releaseVerify.mjs",
    "smoke:updates": "node scripts/updateSmoke.mjs",
    "smoke:updates:local": "node scripts/releaseVerify.mjs",
    "smoke:artifacts:local": "node scripts/releaseVerify.mjs --expect-apk",
    "quality:gate": "npm run lint && npm run test && npm run build && npm run smoke:feeds:local",
    "release:verify": "npm run quality:gate && npm run android:apk && npm run smoke:artifacts:local",
    "start": "node --import tsx server.ts",
    "android:add": "npx cap add android",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:apk": "npm run android:sync && .\\android\\gradlew.bat -p .\\android assembleDebug"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@google/genai": "^1.29.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "telegram": "^2.26.22",
    "three": "^0.183.2",
    "tsx": "^4.21.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
